# LimboOS Kernel Configuration Notes
# For use with build_limboos.sh --compile-kernel
#
# Key options for Limbo PC Emulator (x86):
# - CONFIG_X86_32=y (32-bit) or CONFIG_X86_64=y (64-bit)
# - CONFIG_FRAMEBUFFER_CONSOLE=y
# - CONFIG_FB_VESA=y
# - CONFIG_INPUT_EVDEV=y
# - CONFIG_SERIO_I8042=y
# - CONFIG_INPUT_MOUSE=y
# - CONFIG_MOUSE_PS2=y
# - CONFIG_BLK_DEV_SD=y
# - CONFIG_ATA=y
# - CONFIG_BLK_DEV_RAM=y (initrd support)
# - CONFIG_TMPFS=y
# - CONFIG_MODULES=y
#
# Quick compile (on Linux host):
#   git clone https://git.kernel.org/pub/scm/linux/kernel/git/stable/linux.git
#   cd linux && git checkout v6.1
#   make defconfig
#   make -j$(nproc)
#   cp arch/x86/boot/bzImage build/vmlinuz
